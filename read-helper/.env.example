# Port the helper listens on locally (must match HELPER_PORT in the hosted app).
# HELPER_PORT=9100

# Origin of the hosted MIMICC ENA Submission Assistant that is allowed to drive
# this helper from the browser, e.g. https://mimicc.example.org. localhost is
# always allowed, so this is only needed for a remotely-hosted app.
# MIMICC_APP_ORIGIN=https://mimicc.example.org
