# No credentials are stored in env files — Webin username/password are entered
# in the browser and held in server memory only.
#
# Optional overrides for docker-compose:

# Host directory used as the read-WRITE reads workspace. Put FASTQ/BAM/CRAM
# files here; the server writes generated webin-cli manifests alongside them.
# MIMICC_READS_DIR=/Users/me/mimicc/reads

# Host port to expose the server on (container always listens on 9000
# internally). Useful if 9000 is already taken on your machine.
# MIMICC_PORT=9000

# Path to a local DataHarmonizer checkout, used as a build context to compile
# the embedded DH bundle (server/static/dh/) during `docker compose build`.
# Defaults to the sibling directory ../DataHarmonizer.
# DATAHARMONIZER_DIR=/Users/me/DataHarmonizer

# Host directories backing the DH bundle/schema (used for on-demand rebuilds
# via the mimicc-dh-builder sibling container). Defaults under ~/.mimicc-ena.
# MIMICC_DH_BUNDLE_DIR=/Users/me/.mimicc-ena/dh-bundle
# MIMICC_DH_SCHEMA_DIR=/Users/me/.mimicc-ena/dh-schema
