# Copy to .env and adjust. docker-compose reads .env automatically.
#
# ENA Webin credentials are NOT stored here — they are entered in the browser
# and held in a cache only (never the database). These settings configure the
# app/account system and the database.

# --- Deployment mode -------------------------------------------------------
# "local"  : single user; auto-logs-in as admin, no login screen (default).
# "hosted" : multi-user; login + cookie auth + CSRF are enforced.
# DEPLOYMENT_MODE=local

# --- Admin account ---------------------------------------------------------
# The admin superuser is created/updated from these on every boot (so this is
# the source of truth for the admin password). CHANGE THESE before hosting.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# Secret used by Django for password/session signing. Set a long random value
# for any non-local deployment.
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# --- Database (PostgreSQL, bundled as the "db" compose service) ------------
# POSTGRES_USER=mimicc
# POSTGRES_PASSWORD=mimicc
# POSTGRES_DB=mimicc

# --- Hosting ---------------------------------------------------------------
# Extra cross-origin browser origins allowed to call the API (comma-separated).
# The SPA is same-origin, so this is usually empty; set it if the app is served
# from a different origin than the API. For the local read-helper it is the
# app's own origin, used so the browser page can drive the loopback helper.
# ALLOWED_ORIGINS=https://mimicc.example.org

# Host port to expose the server on (container always listens on 9000).
# MIMICC_PORT=9000

# Loopback port the browser expects the local read-helper on (must match the
# helper's HELPER_PORT).
# HELPER_PORT=9100

# Cache backend for per-user Webin credentials (server/credentials_store.py).
# Unset (the local-mode default) uses an in-process cache — fine for a single
# gunicorn worker. Set this for hosted/multi-worker deployments; pairs with the
# bundled "redis" compose service, which runs with persistence disabled.
# REDIS_URL=redis://redis:6379/0

# --- Build contexts / sidecar ----------------------------------------------
# Path to a local DataHarmonizer checkout, used to compile the embedded DH
# bundle during `docker compose build`. Defaults to ../DataHarmonizer.
# DATAHARMONIZER_DIR=/Users/me/DataHarmonizer

# Path to a local dh-builder checkout (https://github.com/timrozday-mgnify/dh-builder),
# source of scripts/dh_build_steps.sh for the embedded DH-bundle build stage.
# Defaults to ../dh-builder.
# DH_BUILDER_DIR=/Users/me/dh-builder

# Path to a local dataharmonizer-template-builder checkout (the "dhtb" service).
# DHTB_DIR=/Users/me/dataharmonizer-template-builder

# Path to a local read-helper checkout (https://github.com/timrozday-mgnify/read-helper),
# used by the "local" reads-upload profile. Defaults to ../read-helper.
# READ_HELPER_DIR=/Users/me/read-helper

# Host port for the dataharmonizer-template-builder sidecar.
# MIMICC_DHTB_PORT=8765
